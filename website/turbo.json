{
	"extends": ["//"],
	"tasks": {
		"build": {
			"cache": false,
			"dependsOn": ["^build:dev"],
			"outputLogs": "full",
			"outputs": ["dist/**"]
		},
		"dev": {
			"cache": false,
			"dependsOn": ["build"],
			"interactive": false,
			"persistent": true
		},
		"preview": {
			"cache": false,
			"dependsOn": ["build"],
			"persistent": true
		},
		"types:check": {
			"cache": true,
			"dependsOn": ["^build:dev"],
			"outputLogs": "errors-only",
			"outputs": []
		}
	}
}
